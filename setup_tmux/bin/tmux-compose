COMMON_LUA = r"""
state_dir = '<<STATE_DIR>>'
script = '<<SCRIPT>>'

function read_file(path)
    local f = io.open(path, 'r')
    if not f then return '' end
    local content = f:read('*a'); f:close()
    return content
end

function write_file(path, text)
    local f = io.open(path, 'w')
    if f then f:write(text); f:close() end
end

function get_source_pane()
    return read_file(state_dir .. '/source_pane_id'):gsub('%s+$', '')
end

function get_source_label()
    return read_file(state_dir .. '/source_label'):gsub('%s+$', '')
end

vim.keymap.set('n', 'qq', function()
    vim.fn.system('tmux switch-client -l')
end, { noremap = true })
vim.keymap.set('n', 'q?', function()
    vim.fn.system('tmux select-window -t tmux-compose:help')
end, { noremap = true })

function set_wo(win, opt, val)
    local ok = pcall(vim.api.nvim_set_option_value, opt, val, { win = win })
    if not ok then
        pcall(vim.api.nvim_win_set_option, win, opt, val)
    end
end

vim.opt.laststatus = 2
vim.opt.shadafile = 'NONE'
vim.opt.statusline = ' qq=back  q?=help'
"""

HISTORY_LUA = r"""
dofile('<<STATE_DIR>>/common.lua')

local hist_path = '<<STATE_DIR>>/history.txt'

local function load_history()
    local content = read_file(hist_path)
    local lines = vim.split(content, '\n')
    vim.bo.modifiable = true
    vim.api.nvim_buf_set_lines(0, 0, -1, false, lines)
    local ok, baleia = pcall(require, 'baleia')
    if ok then baleia.setup({async = false}).once(0) end
    vim.bo.modifiable = false
    vim.bo.buftype = 'nofile'
    vim.cmd('normal G')
    local label = get_source_label()
    if label ~= '' then
        pcall(vim.api.nvim_buf_set_name, 0, 'history [' .. label .. ']')
    end
end

function reload_history()
    load_history()
end

vim.wo.wrap = false
vim.wo.foldenable = false
vim.wo.number = false
load_history()
"""

