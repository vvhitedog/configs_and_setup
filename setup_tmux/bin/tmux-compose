TODO_LUA = r"""
dofile('<<STATE_DIR>>/common.lua')

local todo_json_path = '<<STATE_DIR>>/todo.json'
local todo_file = '<<TODO_PATH>>'

local f = io.open(todo_json_path, 'r')
if not f then
    vim.notify('No todo items found', vim.log.levels.WARN)
    return
end
local raw = f:read('*a'); f:close()
local items = vim.json.decode(raw)
if not items or not items[1] then
    vim.bo.buftype = 'nofile'
    vim.api.nvim_buf_set_lines(0, 0, -1, false, {'  No todo items. Press a to add one.'})
    vim.bo.modifiable = false
    return
end

-- Build grouped display lines + non_selectable set (MRU picker pattern)
local non_selectable = {}
local row_to_item = {}   -- row -> index into items
local group_labels = {
    TODO = '\u{2610}  TODO',
    ['IN-PROGRESS'] = '\u{25b6}  IN PROGRESS',
    NOTE = '\u{2139}  NOTES',
    DONE = '\u{2714}  DONE',
}
local group_order = { 'TODO', 'IN-PROGRESS', 'NOTE', 'DONE' }

local function build_display()
    local lines = {}
    non_selectable = {}
    row_to_item = {}
    local fold_ranges = {}
    local grouped = {}
    for i, item in ipairs(items) do
        local s = item.status
        if not grouped[s] then grouped[s] = {} end
        table.insert(grouped[s], { idx = i, item = item })
    end
    for _, status in ipairs(group_order) do
        local group = grouped[status]
        if group and #group > 0 then
            if #lines > 0 then
                table.insert(lines, '')
                non_selectable[#lines] = true
            end
            table.insert(lines, ' ' .. (group_labels[status] or status) .. ' (' .. #group .. ')')
            non_selectable[#lines] = true
            local first_item_row = #lines + 1
            for _, entry in ipairs(group) do
                local title = entry.item.title
                local due = (entry.item.due and entry.item.due ~= '') and ('  due:' .. entry.item.due) or ''
                table.insert(lines, '   ' .. title .. due)
                row_to_item[#lines] = entry.idx
            end
            table.insert(fold_ranges, { first = first_item_row, last = #lines })
        end
    end
    return lines, fold_ranges
end

-- Setup buffers
local list_buf = vim.api.nvim_get_current_buf()
vim.bo[list_buf].buftype = 'nofile'
pcall(vim.api.nvim_buf_set_name, list_buf, 'todo')
vim.bo[list_buf].modifiable = false

local preview_buf = vim.api.nvim_create_buf(false, true)
vim.bo[preview_buf].buftype = 'nofile'
vim.bo[preview_buf].modifiable = false

-- Setup windows
local list_win = vim.api.nvim_get_current_win()
vim.cmd('rightbelow vsplit')
local preview_win = vim.api.nvim_get_current_win()
vim.api.nvim_win_set_buf(preview_win, preview_buf)
vim.wo.wrap = false
vim.wo.foldenable = false
vim.wo.number = false
vim.wo.statusline = ' details'

vim.api.nvim_set_current_win(list_win)
vim.cmd('vertical resize ' .. math.floor(vim.o.columns * 0.35))
vim.wo.number = false
vim.wo.cursorline = true
vim.wo.wrap = true
vim.wo.linebreak = true
vim.wo.breakindent = true
vim.wo.breakindentopt = 'shift:5'
vim.wo.foldmethod = 'manual'
vim.wo.foldenable = true
vim.wo.foldlevel = 99

local function refresh_display()
    local lines, fold_ranges = build_display()
    vim.bo[list_buf].modifiable = true
    vim.api.nvim_buf_set_lines(list_buf, 0, -1, false, lines)
    vim.bo[list_buf].modifiable = false
    -- Recreate folds
    pcall(function()
        vim.api.nvim_set_current_win(list_win)
        vim.cmd('normal! zE')
        for _, range in ipairs(fold_ranges) do
            if range.first <= range.last then
                vim.cmd(range.first .. ',' .. range.last .. 'fold')
                vim.cmd(range.first .. 'foldopen')
            end
        end
    end)
end

refresh_display()

-- Navigation (copied from MRU picker)
local function find_first_selectable()
    local total = vim.api.nvim_buf_line_count(list_buf)
    for i = 1, total do
        if not non_selectable[i] then return i end
    end
    return 1
end

vim.keymap.set('n', 'j', function()
    local row = vim.api.nvim_win_get_cursor(list_win)[1]
    local total = vim.api.nvim_buf_line_count(list_buf)
    for r = row + 1, total do
        if not non_selectable[r] then
            pcall(vim.api.nvim_win_set_cursor, list_win, {r, 0})
            return
        end
    end
end, { buffer = list_buf, noremap = true })

vim.keymap.set('n', 'k', function()
    local row = vim.api.nvim_win_get_cursor(list_win)[1]
    for r = row - 1, 1, -1 do
        if not non_selectable[r] then
            pcall(vim.api.nvim_win_set_cursor, list_win, {r, 0})
            return
        end
    end
end, { buffer = list_buf, noremap = true })

local function snap_to_selectable()
    local row = vim.api.nvim_win_get_cursor(list_win)[1]
    if non_selectable[row] then
        local total = vim.api.nvim_buf_line_count(list_buf)
        for r = row + 1, total do
            if not non_selectable[r] then
                pcall(vim.api.nvim_win_set_cursor, list_win, {r, 0})
                return
            end
        end
        for r = row - 1, 1, -1 do
            if not non_selectable[r] then
                pcall(vim.api.nvim_win_set_cursor, list_win, {r, 0})
                return
            end
        end
    end
end

for _, key in ipairs({'<C-d>', '<C-u>', '<C-f>', '<C-b>', '<PageDown>', '<PageUp>'}) do
    vim.keymap.set('n', key, function()
        vim.cmd('normal! ' .. vim.api.nvim_replace_termcodes(key, true, false, true))
        snap_to_selectable()
    end, { buffer = list_buf, noremap = true })
end

vim.keymap.set('n', 'G', function()
    vim.cmd('normal! G')
    snap_to_selectable()
end, { buffer = list_buf, noremap = true })

vim.keymap.set('n', 'gg', function()
