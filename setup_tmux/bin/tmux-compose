-- Preview
local function get_item_at_cursor()
    local row = vim.api.nvim_win_get_cursor(list_win)[1]
    local idx = row_to_item[row]
    if not idx then return nil, row end
    return items[idx], row
end

local function update_preview()
    local item = get_item_at_cursor()
    if not item then return end
    local tf = io.open(item.detail_path, 'r')
    if not tf then return end
    local content = tf:read('*a'); tf:close()
    vim.bo[preview_buf].modifiable = true
    vim.api.nvim_buf_set_lines(preview_buf, 0, -1, false, vim.split(content, '\n'))
    vim.bo[preview_buf].modifiable = false
    pcall(vim.api.nvim_win_set_option, preview_win, 'statusline',
        ' [' .. item.status .. '] ' .. item.title)
end

vim.api.nvim_create_autocmd('CursorMoved', {
    buffer = list_buf,
    callback = function()
        snap_to_selectable()
        update_preview()
    end,
})

-- Initial position
pcall(vim.api.nvim_win_set_cursor, list_win, {find_first_selectable(), 0})
update_preview()

-- Actions
local function reload_items()
    vim.fn.system(script .. ' --todo-refresh')
    local f2 = io.open(todo_json_path, 'r')
    if not f2 then return end
    local raw2 = f2:read('*a'); f2:close()
    local new_items = vim.json.decode(raw2)
    if new_items then items = new_items end
    refresh_display()
    snap_to_selectable()
    update_preview()
end

local next_status = {
    TODO = 'IN-PROGRESS',
    ['IN-PROGRESS'] = 'DONE',
    DONE = 'TODO',
    NOTE = 'DONE',
}

vim.keymap.set('n', 'd', function()
    local item, row = get_item_at_cursor()
    if not item then return end
    local ns = next_status[item.status] or 'TODO'
    vim.fn.system(script .. ' --todo-status ' .. item.line_start .. ' ' .. ns)
    vim.notify(item.title .. ': ' .. item.status .. ' -> ' .. ns .. ' (committed)', vim.log.levels.INFO)
    reload_items()
    pcall(vim.api.nvim_win_set_cursor, list_win, {math.min(row, vim.api.nvim_buf_line_count(list_buf)), 0})
    snap_to_selectable()
end, { buffer = list_buf, noremap = true })

