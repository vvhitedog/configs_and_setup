# ---------------------------------------------------------------------------
# Session recovery (snapshot / resume)
# ---------------------------------------------------------------------------

def capture_sessions():
    """Snapshot every live session's layout.

    Returns {session_name: [{index, name, cwd}, ...]} (windows sorted by
    index), excluding the tmux-compose helper session. Returns None when the
    tmux server is unreachable, so callers can tell "nothing to save" apart
    from "couldn't ask" and avoid clobbering a good snapshot at crash time.
    """
    try:
        out = subprocess.run(
            ["tmux", "list-windows", "-a", "-F",
             "#{session_name}\t#{window_index}\t#{window_name}\t#{pane_current_path}"],
            capture_output=True, text=True, timeout=10,
        )
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return None
    if out.returncode != 0:
        return None  # no server running, or tmux error
    sessions = {}
    for line in out.stdout.splitlines():
        parts = line.split("\t")
        if len(parts) < 4:
            continue
        sname, idx, wname, cwd = parts[0], parts[1], parts[2], parts[3]
        if sname == COMPOSE_SESSION:
            continue
        try:
            idx_i = int(idx)
        except ValueError:
            continue
        sessions.setdefault(sname, []).append(
            {"index": idx_i, "name": wname, "cwd": cwd})
    for wins in sessions.values():
        wins.sort(key=lambda w: w["index"])
    return sessions


def cmd_snapshot():
    """Write the current layout to RECOVERY_FILE (atomic, with one backup).

    Fails safe: if the tmux server is down or only the helper session exists,
    the existing snapshot is left untouched rather than overwritten with
    nothing — a recovery tool should never lose good data because it happened
    to run mid-crash.
    """
    sessions = capture_sessions()
    if sessions is None:
        return  # tmux unreachable — keep last good snapshot
    if not sessions:
        return  # no real sessions — don't overwrite with emptiness

    data = {
        "version": RECOVERY_VERSION,
        "saved_at": datetime.now().isoformat(timespec="seconds"),
        "sessions": [
            {"name": name, "windows": wins}
            for name, wins in sorted(sessions.items())
        ],
    }
    os.makedirs(RECOVERY_DIR, exist_ok=True)
    if os.path.exists(RECOVERY_FILE):
        try:
            shutil.copy2(RECOVERY_FILE, RECOVERY_BAK)
        except OSError:
            pass
    tmp = RECOVERY_FILE + ".tmp"
    with open(tmp, "w") as f:
        json.dump(data, f, indent=2)
        f.flush()
        os.fsync(f.fileno())
    os.replace(tmp, RECOVERY_FILE)  # atomic on POSIX


def load_snapshot():
    """Return (data, source_path) from the snapshot, falling back to the
    backup if the primary is missing or corrupt. (None, None) if neither
    is usable."""
    for path in (RECOVERY_FILE, RECOVERY_BAK):
        try:
            with open(path) as f:
                data = json.load(f)
        except (FileNotFoundError, json.JSONDecodeError, OSError):
            continue
        if isinstance(data, dict) and isinstance(data.get("sessions"), list):
            return data, path
    return None, None


def live_session_names():
    try:
        out = subprocess.run(
            ["tmux", "list-sessions", "-F", "#{session_name}"],
            capture_output=True, text=True, timeout=10,
        )
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return set()
    if out.returncode != 0:
        return set()  # no server == no live sessions
    return set(out.stdout.split())


def restore_session(sess):
    """Recreate one session: windows in saved order, exact names, saved cwd
    (falling back to $HOME if the dir is gone). Returns (ok, message)."""
    name = sess.get("name")
    windows = sorted(sess.get("windows", []), key=lambda w: int(w.get("index", 0)))
    if not name or not windows:
        return False, "no windows"

    def safe_cwd(w):
        cwd = w.get("cwd") or ""
        return cwd if cwd and os.path.isdir(cwd) else os.path.expanduser("~")

    def lock_name(win_id):
        # Pin the saved name: disable automatic-rename so a shell/command can't
        # overwrite it. (new-window -n already disables it on modern tmux; this
        # makes the guarantee explicit and version-proof.)
        if win_id:
            subprocess.run(["tmux", "set-window-option", "-t", win_id,
                            "automatic-rename", "off"], capture_output=True)

    first = windows[0]
    r = subprocess.run(
        ["tmux", "new-session", "-d", "-s", name,
         "-n", first.get("name") or "win", "-c", safe_cwd(first),
         "-P", "-F", "#{window_id}"],
        capture_output=True, text=True,
    )
    if r.returncode != 0:
        return False, (r.stderr.strip() or "new-session failed")
    lock_name(r.stdout.strip())

    for w in windows[1:]:
        r = subprocess.run(
            ["tmux", "new-window", "-t", name + ":",
             "-n", w.get("name") or "win", "-c", safe_cwd(w),
             "-P", "-F", "#{window_id}"],
            capture_output=True, text=True,
        )
        if r.returncode == 0:
            lock_name(r.stdout.strip())
    return True, f"{len(windows)} window(s)"


def cmd_resume(args):
    """Show stored sessions and rebuild the ones that aren't already running.

    Usage:
      tmux-compose resume            # show snapshot + restore all missing
      tmux-compose resume --list     # show snapshot only, restore nothing
      tmux-compose resume <name>...  # restore only the named session(s)
    """
    list_only = "--list" in args
    targets = [a for a in args if not a.startswith("-")]

    data, src = load_snapshot()
    if not data:
        print("tmux-compose: no recovery snapshot found.")
        print("  Take one with:  tmux-compose snapshot")
        print("  (or enable the periodic snapshot timer)")
        return

    stored = data.get("sessions", [])
    live = live_session_names()

    note = "  (restored from backup)" if src == RECOVERY_BAK else ""
    print(f"Recovery snapshot — saved {data.get('saved_at', '?')}{note}")
    print(f"{len(stored)} session(s) stored:\n")
    for s in stored:
        nm = s.get("name", "?")
        wins = sorted(s.get("windows", []), key=lambda w: int(w.get("index", 0)))
        running = nm in live
        mark = "•" if running else "+"
        print(f"  {mark} {nm:<24} {len(wins):>2} window(s)   "
              f"[{'already running' if running else 'resumable'}]")
        for w in wins:
            print(f"        {str(w.get('index')):>2}  {(w.get('name') or '?'):<18} {w.get('cwd', '')}")
    print()

    if list_only:
        return

    to_restore = [
        s for s in stored
        if (not targets or s.get("name") in targets) and s.get("name") not in live
    ]
    if not to_restore:
        if targets:
            print("Nothing to restore (named session(s) already running or not stored).")
        else:
            print("All stored sessions are already running — nothing to restore.")
        return

    print("Restoring:")
    for s in to_restore:
        ok, msg = restore_session(s)
        print(f"  {'✓' if ok else '✗'} {s.get('name'):<24} {msg}")
    print("\nDone.  Attach with:  tmux attach -t <session>")


# ---------------------------------------------------------------------------
# Session management
# ---------------------------------------------------------------------------

def session_exists():
    r = subprocess.run(
        ["tmux", "has-session", "-t", COMPOSE_SESSION],
        capture_output=True,
    )
    return r.returncode == 0


def ensure_state_dir():
    os.makedirs(STATE_DIR, exist_ok=True)
    os.makedirs(os.path.join(STATE_DIR, "tails"), exist_ok=True)
    os.makedirs(os.path.join(STATE_DIR, "todo_details"), exist_ok=True)


def write_lua_files():
    script_path = os.path.abspath(sys.argv[0])
    for name, template in [
        ("common.lua", COMMON_LUA),
        ("history.lua", HISTORY_LUA),
        ("compose.lua", COMPOSE_LUA),
        ("terminals.lua", TERMINALS_LUA),
        ("status.lua", STATUS_LUA),
        ("help.lua", HELP_LUA),
        ("todo.lua", TODO_LUA),
    ]:
        content = template.replace("<<STATE_DIR>>", STATE_DIR.replace("'", "\\'"))
        content = content.replace("<<SCRIPT>>", script_path.replace("'", "\\'"))
        content = content.replace("<<TODO_PATH>>", TODO_PATH.replace("'", "\\'"))
        with open(os.path.join(STATE_DIR, name), "w") as f:
            f.write(content)


def write_source_pane(pane_id):
    label = get_pane_label(pane_id)
    with open(os.path.join(STATE_DIR, "source_pane_id"), "w") as f:
        f.write(pane_id)
    with open(os.path.join(STATE_DIR, "source_label"), "w") as f:
        f.write(label)


def refresh_history(pane_id):
    tkey = resolve_terminal_key(pane_id)
    subprocess.run(
        [sys.executable, os.path.expanduser("~/.local/bin/tmux-pane-history"),
         "capture", pane_id],
        capture_output=True,
    )
    history = get_merged_history(tkey)
    if not history:
        try:
            history = subprocess.check_output(
                ["tmux", "capture-pane", "-t", pane_id, "-p", "-e", "-S", "-"],
                text=True,
            )
        except subprocess.CalledProcessError:
            history = ""
    with open(os.path.join(STATE_DIR, "history.txt"), "w") as f:
        f.write(strip_vt100_controls(history))


def refresh_terminals_data():
    term_hists = get_terminal_histories()
    notes = get_notes()
    tails_dir = os.path.join(STATE_DIR, "tails")
    if os.path.exists(tails_dir):
        shutil.rmtree(tails_dir)
    os.makedirs(tails_dir, exist_ok=True)
    terminals_data = []
    for t_pane_id, content_len, last_ts, db_label in term_hists:
        try:
            ts_str = datetime.fromtimestamp(int(last_ts)).strftime("%m/%d %H:%M") if last_ts else "?"
        except (ValueError, TypeError):
            ts_str = "?"
        tail_path = os.path.join(tails_dir,
                                 t_pane_id.replace("%", "p").replace("@", "_") + ".txt")
        with open(tail_path, "w") as f:
            f.write(get_merged_history_tail(t_pane_id, 500))
        terminals_data.append({
            "pane": t_pane_id,
            "label": db_label or t_pane_id,
            "date": ts_str,
            "size_kb": content_len // 1024,
            "tail_path": tail_path,
            "note": notes.get(t_pane_id, "") or notes.get(t_pane_id.split("@")[0], ""),
        })
    with open(os.path.join(STATE_DIR, "terminals.json"), "w") as f:
        json.dump(terminals_data, f)


def refresh_recent_data():
    recent = get_recent_compositions(20)
    recent_data = [{"date": (c[1] or "?")[:19], "pane": c[2], "content": c[0]} for c in recent]
    with open(os.path.join(STATE_DIR, "recent.json"), "w") as f:
        json.dump(recent_data, f)


def create_compose_session():
    try:
        cols = subprocess.check_output(
            ["tmux", "display-message", "-p", "#{window_width}"], text=True
        ).strip()
        rows = subprocess.check_output(
            ["tmux", "display-message", "-p", "#{window_height}"], text=True
        ).strip()
    except subprocess.CalledProcessError:
        cols, rows = "200", "50"

    hist_file = os.path.join(STATE_DIR, "history.txt")
    compose_file = os.path.join(STATE_DIR, "compose.txt")
    help_file = os.path.join(STATE_DIR, "help.txt")

    if not os.path.exists(compose_file):
        with open(compose_file, "w") as f:
            f.write("")

    nvim_base = ["nvim", "--cmd", "set shadafile=NONE"]

    subprocess.run([
        "tmux", "new-session", "-d", "-s", COMPOSE_SESSION,
        "-n", "history", "-x", cols, "-y", rows,
        *nvim_base, "-S", os.path.join(STATE_DIR, "history.lua"), hist_file,
    ])
    subprocess.run([
        "tmux", "new-window", "-t", COMPOSE_SESSION,
        "-n", "compose",
        *nvim_base, "-S", os.path.join(STATE_DIR, "compose.lua"), compose_file,
    ])
    subprocess.run([
        "tmux", "new-window", "-t", COMPOSE_SESSION,
        "-n", "terminals",
        *nvim_base, "-S", os.path.join(STATE_DIR, "terminals.lua"),
    ])
    subprocess.run([
        "tmux", "new-window", "-t", COMPOSE_SESSION,
        "-n", "status",
        *nvim_base, "-S", os.path.join(STATE_DIR, "status.lua"),
    ])
    subprocess.run([
        "tmux", "new-window", "-t", COMPOSE_SESSION,
        "-n", "help",
        *nvim_base, "-S", os.path.join(STATE_DIR, "help.lua"), help_file,
    ])
    subprocess.run([
        "tmux", "new-window", "-t", COMPOSE_SESSION,
        "-n", "todo",
        *nvim_base, "--cmd", "let g:loaded_netrwPlugin=1", "-S", os.path.join(STATE_DIR, "todo.lua"),
    ])
    subprocess.run([
        "tmux", "new-window", "-t", COMPOSE_SESSION,
        "-n", "btop",
        "btop",
    ])


# ---------------------------------------------------------------------------
# Main subcommands
# ---------------------------------------------------------------------------

def cmd_ensure(pane_id, target_window):
    ensure_state_dir()
    write_lua_files()
    write_source_pane(pane_id)

    with open(os.path.join(STATE_DIR, "help.txt"), "w") as f:
        f.write(HELP_TEXT)

    if target_window == "history":
        refresh_history(pane_id)
    elif target_window == "terminals":
        refresh_terminals_data()
    elif target_window == "todo":
        refresh_todo_data()

    if not session_exists():
        if target_window != "history":
            refresh_history(pane_id)
        if target_window != "terminals":
            refresh_terminals_data()
        refresh_todo_data()
        refresh_recent_data()
        create_compose_session()
    else:
        # Check if target window exists, recreate if missing
        r = subprocess.run(
            ["tmux", "list-windows", "-t", COMPOSE_SESSION,
             "-F", "#{window_name}"],
            capture_output=True, text=True,
        )
        existing_windows = set(r.stdout.strip().splitlines()) if r.returncode == 0 else set()

        nvim_base = ["nvim", "--cmd", "set shadafile=NONE"]
        hist_file = os.path.join(STATE_DIR, "history.txt")
        compose_file = os.path.join(STATE_DIR, "compose.txt")
        help_file = os.path.join(STATE_DIR, "help.txt")

        if not os.path.exists(compose_file):
            with open(compose_file, "w") as f:
                f.write("")

        window_cmds = {
            "history": [*nvim_base, "-S", os.path.join(STATE_DIR, "history.lua"), hist_file],
            "compose": [*nvim_base, "-S", os.path.join(STATE_DIR, "compose.lua"), compose_file],
            "terminals": [*nvim_base, "-S", os.path.join(STATE_DIR, "terminals.lua")],
            "status": [*nvim_base, "-S", os.path.join(STATE_DIR, "status.lua")],
            "help": [*nvim_base, "-S", os.path.join(STATE_DIR, "help.lua"), help_file],
            "todo": [*nvim_base, "--cmd", "let g:loaded_netrwPlugin=1", "-S", os.path.join(STATE_DIR, "todo.lua")],
            "btop": ["btop"],
        }

        for wname, wcmd in window_cmds.items():
            if wname not in existing_windows:
                subprocess.run([
                    "tmux", "new-window", "-t", COMPOSE_SESSION,
                    "-n", wname, *wcmd,
                ])

        # Signal running nvim to reload if window was already alive
        if target_window == "history" and "history" in existing_windows:
            subprocess.run([
                "tmux", "send-keys", "-t", f"{COMPOSE_SESSION}:history",
                ":silent lua reload_history()", "Enter",
            ])
        elif target_window == "status" and "status" in existing_windows:
            subprocess.run([
                "tmux", "send-keys", "-t", f"{COMPOSE_SESSION}:status",
                ":silent lua refresh_status()", "Enter",
            ])
        elif target_window == "todo" and "todo" in existing_windows:
            # Kill and recreate to get fresh data
            subprocess.run([
                "tmux", "kill-window", "-t", f"{COMPOSE_SESSION}:todo",
            ], capture_output=True)
            subprocess.run([
                "tmux", "new-window", "-t", COMPOSE_SESSION,
                "-n", "todo",
                *window_cmds["todo"],
            ])


def cmd_send_compose():
    source_file = os.path.join(STATE_DIR, "source_pane_id")
    compose_file = os.path.join(STATE_DIR, "compose.txt")
    if not os.path.exists(source_file) or not os.path.exists(compose_file):
        return
    with open(source_file) as f:
        pane_id = f.read().strip()
    with open(compose_file) as f:
        content = f.read().strip()
    if not content:
        return
    save_composition(get_pane_label(pane_id), content)
    buf_file = tempfile.mktemp(prefix="tmux_paste_")
    with open(buf_file, "w") as f:
        f.write(content)
    subprocess.run(["tmux", "load-buffer", buf_file])
    subprocess.run(["tmux", "paste-buffer", "-t", pane_id, "-d"])
    os.unlink(buf_file)


def cmd_clip_compose():
    compose_file = os.path.join(STATE_DIR, "compose.txt")
    source_file = os.path.join(STATE_DIR, "source_pane_id")
    if not os.path.exists(compose_file):
        return
    with open(compose_file) as f:
        content = f.read().strip()
    if not content:
        return
    label = "clipboard"
    if os.path.exists(source_file):
        with open(source_file) as f:
            label = get_pane_label(f.read().strip())
    save_composition(label, content)
    subprocess.run(["tmux", "set-buffer", content])
    for clip_cmd in [["xclip", "-selection", "clipboard"],
                     ["xsel", "--clipboard", "--input"],
                     ["wl-copy"]]:
        try:
            subprocess.run(clip_cmd, input=content, text=True,
                           timeout=2, stderr=subprocess.DEVNULL)
            break
        except (FileNotFoundError, subprocess.TimeoutExpired):
            continue


def cmd_refresh_history(pane_key):
    content = get_merged_history(pane_key)
    if not content:
        return
    with open(os.path.join(STATE_DIR, "history.txt"), "w") as f:
        f.write(strip_vt100_controls(content))
    # Update label
    conn = sqlite3.connect(DB_PATH)
    conn.execute("PRAGMA journal_mode=WAL")
    row = conn.execute(
        "SELECT label FROM merged WHERE pane_id = ?", (pane_key,)
    ).fetchone()
    conn.close()
    with open(os.path.join(STATE_DIR, "source_label"), "w") as f:
        f.write(row[0] if row and row[0] else pane_key)
    if session_exists():
        subprocess.run([
            "tmux", "send-keys", "-t", f"{COMPOSE_SESSION}:history",
            ":silent lua reload_history()", "Enter",
        ])


def cmd_reset():
    subprocess.run(
        ["tmux", "kill-session", "-t", COMPOSE_SESSION],
        capture_output=True,
    )
    if os.path.exists(STATE_DIR):
        shutil.rmtree(STATE_DIR)
    print("Reset complete.")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main():
    if len(sys.argv) < 2:
        print("Usage: tmux-compose <ensure|fork|send-compose|clip-compose|refresh-history|reset|snapshot|resume|--search|--note|--dump|--status>")
        sys.exit(1)

    cmd = sys.argv[1]
    if cmd in ("-h", "--help", "help"):
        print(HELP_TEXT)
        return
    if cmd == "snapshot":
        cmd_snapshot()
        return
    if cmd == "resume":
        cmd_resume(sys.argv[2:])
        return
    if cmd == "fork":
        cmd_fork(sys.argv[2:])
        return
    if cmd == "fork-prompt":
        cmd_fork_prompt(sys.argv[2:])
        return
    if cmd == "--search":
        cmd_search(sys.argv[2:])
    elif cmd == "--note":
        cmd_note(sys.argv[2:])
    elif cmd == "--dump":
        cmd_dump(sys.argv[2:])
    elif cmd == "--status":
        cmd_status(sys.argv[2:])
    elif cmd == "ensure" and len(sys.argv) >= 4:
        cmd_ensure(sys.argv[2], sys.argv[3])
    elif cmd == "send-compose":
        cmd_send_compose()
    elif cmd == "clip-compose":
        cmd_clip_compose()
    elif cmd == "refresh-history" and len(sys.argv) >= 3:
        cmd_refresh_history(sys.argv[2])
    elif cmd == "--todo-add":
        cmd_todo_add(sys.argv[2:])
    elif cmd == "--todo-status":
        cmd_todo_update_status(sys.argv[2:])
    elif cmd == "--todo-refresh":
        refresh_todo_data()
    elif cmd == "--todo-commit":
        git_commit_todo(" ".join(sys.argv[2:]) if len(sys.argv) > 2 else "Edit todo")
    elif cmd == "reset":
        cmd_reset()
    elif cmd == "create-window" and len(sys.argv) >= 3:
        cmd_create_window(sys.argv[2])
    elif cmd == "create-split" and len(sys.argv) >= 3:
        cmd_create_split(sys.argv[2])
    elif cmd == "--toggle-prompt-on-create":
        cmd_toggle_prompt_on_create()
    elif cmd == "--get-prompt-on-create":
        print("on" if get_prompt_on_create() else "off")
    elif cmd == "--toggle-codex-auto-edits":
        cmd_toggle_codex_auto_edits()
    elif cmd == "--get-codex-auto-edits":
        print("on" if get_codex_auto_edits() else "off")
    elif cmd == "--toggle-codex-approve-all":
        cmd_toggle_codex_approve_all()
    elif cmd == "--get-codex-approve-all":
        print("on" if get_codex_approve_all() else "off")
    else:
        print(f"Unknown command: {cmd}")
        sys.exit(1)


if __name__ == "__main__":
    main()
