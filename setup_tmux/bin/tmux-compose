TERMINALS_LUA = r"""
dofile('<<STATE_DIR>>/common.lua')

local terminals_json_path = '<<STATE_DIR>>/terminals.json'
local search_counts = {}

local f = io.open(terminals_json_path, 'r')
if not f then
    vim.notify('No terminal histories', vim.log.levels.WARN)
    return
end
local raw = f:read('*a'); f:close()
local items = vim.json.decode(raw)
if not items or #items == 0 then
    vim.notify('No terminal histories', vim.log.levels.WARN)
    return
end

local preview_buf = vim.api.nvim_create_buf(false, true)
vim.bo[preview_buf].buftype = 'nofile'
vim.bo[preview_buf].modifiable = false

local list_buf = vim.api.nvim_get_current_buf()
vim.bo[list_buf].buftype = 'nofile'
pcall(vim.api.nvim_buf_set_name, list_buf, 'terminals')

local function refresh_list()
    local lines = {}
    for _, item in ipairs(items) do
        local count_str = search_counts[item.pane] and (' [' .. search_counts[item.pane] .. ']') or ''
        local note_str = (item.note and item.note ~= '') and (' | ' .. item.note:sub(1, 30)) or ''
        local display = item.label or item.pane
        table.insert(lines, string.format(' %s %s %dK%s%s',
            item.date, display, item.size_kb or 0, count_str, note_str))
    end
    vim.bo[list_buf].modifiable = true
    vim.api.nvim_buf_set_lines(list_buf, 0, -1, false, lines)
    vim.bo[list_buf].modifiable = false
end
refresh_list()

-- list_buf is current buffer. Create preview split on right.
local list_win = vim.api.nvim_get_current_win()
vim.cmd('rightbelow vsplit')
local preview_win = vim.api.nvim_get_current_win()
vim.api.nvim_win_set_buf(preview_win, preview_buf)
set_wo(preview_win, 'wrap', false)
set_wo(preview_win, 'foldenable', false)
set_wo(preview_win, 'number', false)
set_wo(preview_win, 'statusline', ' preview')

-- Focus list and make it narrow (30%), preview gets 70%
vim.api.nvim_set_current_win(list_win)
vim.cmd('vertical resize ' .. math.floor(vim.o.columns * 0.30))
set_wo(list_win, 'number', false)
set_wo(list_win, 'cursorline', true)
set_wo(list_win, 'wrap', false)
set_wo(list_win, 'foldenable', false)

local function update_preview()
    local row = vim.api.nvim_win_get_cursor(list_win)[1]
    local item = items[row]
    if not item then return end
    local tf = io.open(item.tail_path, 'r')
    if not tf then return end
    local content = tf:read('*a'); tf:close()
    vim.bo[preview_buf].modifiable = true
    vim.api.nvim_buf_set_lines(preview_buf, 0, -1, false, vim.split(content, '\n'))
    local bok, bmod = pcall(require, 'baleia')
    if bok then bmod.setup({async = false}).once(preview_buf) end
    vim.bo[preview_buf].modifiable = false
    pcall(vim.api.nvim_win_set_cursor, preview_win,
        {vim.api.nvim_buf_line_count(preview_buf), 0})
    set_wo(preview_win, 'statusline', (item.note and item.note ~= '')
        and (' note: ' .. item.note) or ' preview')
end
vim.api.nvim_create_autocmd('CursorMoved', { buffer = list_buf, callback = update_preview })
update_preview()

vim.keymap.set('n', '<CR>', function()
    local row = vim.api.nvim_win_get_cursor(0)[1]
    local item = items[row]
    if not item then return end
    vim.fn.system(script .. ' refresh-history ' .. vim.fn.shellescape(item.pane))
    vim.fn.system('tmux select-window -t tmux-compose:history')
end, { buffer = list_buf, noremap = true })

vim.keymap.set('n', '/', function()
    vim.ui.input({ prompt = 'Search terminals: ' }, function(pattern)
        if not pattern or pattern == '' then search_counts = {}; refresh_list(); return end
        local out = vim.fn.system(script .. ' --search ' .. vim.fn.shellescape(pattern))
        local ok2, counts = pcall(vim.json.decode, out)
        search_counts = (ok2 and counts) or {}
        refresh_list()
        vim.notify(vim.tbl_count(search_counts) .. ' terminals matched', vim.log.levels.INFO)
    end)
end, { buffer = list_buf, noremap = true })

vim.keymap.set('n', 'n', function()
    local row = vim.api.nvim_win_get_cursor(0)[1]
    local item = items[row]
    if not item then return end
    vim.ui.input({
        prompt = 'Note for ' .. (item.label or item.pane) .. ': ',
        default = item.note or '',
    }, function(note)
        if note == nil then return end
        item.note = note
        vim.fn.system(script .. ' --note ' .. vim.fn.shellescape(item.pane) .. ' ' .. vim.fn.shellescape(note))
        refresh_list(); update_preview()
    end)
end, { buffer = list_buf, noremap = true })

set_wo(list_win, 'statusline', ' Enter=view  /=search  n=note  │  qq=back')
"""

STATUS_LUA = r"""
dofile('<<STATE_DIR>>/common.lua')

local status_buf = vim.api.nvim_get_current_buf()
vim.bo.buftype = 'nofile'
pcall(vim.api.nvim_buf_set_name, status_buf, 'status')
vim.wo.number = false; vim.wo.cursorline = true
vim.wo.wrap = false; vim.wo.foldenable = false

function refresh_status()
    local out = vim.fn.system(script .. ' --status')
    local ok, svcs = pcall(vim.json.decode, out)
    if not ok then return end
    local lines = {' Service Status', ' ──────────────────────────────────────────'}
    for _, s in ipairs(svcs) do
        local icon = s.state == 'active' and ' [running]' or ' [stopped]'
        local pid_str = (s.pid ~= '0' and s.pid ~= '') and ('  pid=' .. s.pid) or ''
        local started = s.started ~= '' and ('  since ' .. s.started) or ''
        table.insert(lines, string.format(' %s%s%s%s', s.name, icon, pid_str, started))
    end

    -- Settings section (read live values from tmux-compose CLI)
    local prompt_state = (vim.fn.system(script .. ' --get-prompt-on-create')):gsub('%s+', '')
    local codex_edits  = (vim.fn.system(script .. ' --get-codex-auto-edits')):gsub('%s+', '')
    local codex_appall = (vim.fn.system(script .. ' --get-codex-approve-all')):gsub('%s+', '')
    table.insert(lines, '')
    table.insert(lines, ' Settings')
    table.insert(lines, ' ──────────────────────────────────────────')
    table.insert(lines, ' prompt-on-create:  ' .. (prompt_state == 'on' and 'on ' or 'off')
                                              .. '   (prompts for window name on prefix+C)')
    table.insert(lines, ' codex auto-edits:  ' .. (codex_edits == 'on' and 'on ' or 'off')
                                              .. '   (codex-auto-approve edits prompts)')
    table.insert(lines, ' codex approve-all: ' .. (codex_appall == 'on' and 'on ' or 'off')
                                              .. '   (auto-approve ALL cmds except denylist)')

    table.insert(lines, '')
    table.insert(lines, ' r=restart  s=start  p=prompt  e=edits  a=approve-all  R=refresh  qq=back')
    vim.bo[status_buf].modifiable = true
    vim.api.nvim_buf_set_lines(status_buf, 0, -1, false, lines)
    vim.bo[status_buf].modifiable = false
end
refresh_status()

local function get_svc_name()
    local line = vim.api.nvim_get_current_line()
    for _, name in ipairs({'tmux-pane-history', 'tmux-window-usage', 'claude-auto-approve', 'cursor-auto-approve', 'codex-auto-approve'}) do
        if line:find(name, 1, true) then return name end
    end
end

vim.keymap.set('n', 'r', function()
    local svc = get_svc_name()
    if svc then
        vim.fn.system('systemctl --user restart ' .. svc .. '.service')
        vim.notify('Restarted ' .. svc, vim.log.levels.INFO)
        vim.defer_fn(refresh_status, 500)
    end
end, { buffer = status_buf, noremap = true })

vim.keymap.set('n', 's', function()
    local svc = get_svc_name()
    if svc then
        vim.fn.system('systemctl --user start ' .. svc .. '.service')
        vim.notify('Started ' .. svc, vim.log.levels.INFO)
        vim.defer_fn(refresh_status, 500)
    end
end, { buffer = status_buf, noremap = true })

vim.keymap.set('n', 'R', refresh_status, { buffer = status_buf, noremap = true })

vim.keymap.set('n', 'p', function()
    local new_state = (vim.fn.system(script .. ' --toggle-prompt-on-create')):gsub('%s+', '')
    vim.notify('prompt-on-create: ' .. new_state, vim.log.levels.INFO)
    refresh_status()
end, { buffer = status_buf, noremap = true })

vim.keymap.set('n', 'e', function()
    local new_state = (vim.fn.system(script .. ' --toggle-codex-auto-edits')):gsub('%s+', '')
    vim.notify('codex auto-edits: ' .. new_state .. ' (codex-auto-approve restarted)', vim.log.levels.INFO)
    refresh_status()
end, { buffer = status_buf, noremap = true })

vim.keymap.set('n', 'a', function()
    local new_state = (vim.fn.system(script .. ' --toggle-codex-approve-all')):gsub('%s+', '')
    vim.notify('codex approve-all: ' .. new_state .. ' (codex-auto-approve restarted)', vim.log.levels.INFO)
    refresh_status()
end, { buffer = status_buf, noremap = true })

vim.wo.statusline = ' r=restart  s=start  p=prompt  e=edits  a=approve-all  R=refresh  │  qq=back'
"""

