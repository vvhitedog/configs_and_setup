#!/usr/bin/env python3
"""Tmux terminal toolkit — persistent tmux-compose session with history, compose, terminals, status, help."""

import argparse
import json
import os
import re
import shlex
import shutil
import subprocess
import sys
import sqlite3
import tempfile
from datetime import datetime

DB_PATH = os.path.expanduser("~/.cache/tmux/pane-history.db")
STATE_DIR = os.path.expanduser("~/.cache/tmux/compose-state")
COMPOSE_SESSION = "tmux-compose"

# --- Session recovery -----------------------------------------------------
# A crash (e.g. OOM during a compile) kills the tmux server and every session
# with it. We periodically snapshot the *layout* — session names, window order,
# window names, and each window's workdir — to a single JSON file so it can be
# rebuilt with `tmux-compose resume`. Deliberately minimal: no scrollback, no
# running commands, no pane splits — apps checkpoint their own state.
RECOVERY_DIR = os.path.expanduser("~/.cache/tmux/recovery")
RECOVERY_FILE = os.path.join(RECOVERY_DIR, "sessions.json")
RECOVERY_BAK = os.path.join(RECOVERY_DIR, "sessions.json.bak")
RECOVERY_VERSION = 1
_VT100_CTRL_RE = re.compile(r"[\x0e\x0f]")
TODO_PATH = os.path.expanduser("~/todo/todo.md")
TODO_REPO = os.path.expanduser("~/todo")

SERVICES = [
    "tmux-pane-history",
    "tmux-window-usage",
    "claude-auto-approve",
    "cursor-auto-approve",
    "codex-auto-approve",
]

# --- Settings -----------------------------------------------------------
# Whether `create-window` / `create-split` should pop a `command-prompt`
# asking for a window name after creating. Toggled from the status screen.
PROMPT_ON_CREATE_FILE = os.path.join(STATE_DIR, "prompt_on_create")


def get_prompt_on_create():
    try:
        with open(PROMPT_ON_CREATE_FILE) as f:
            return f.read().strip().lower() in ("on", "1", "true", "yes")
    except FileNotFoundError:
        return False


def set_prompt_on_create(val):
    os.makedirs(STATE_DIR, exist_ok=True)
    with open(PROMPT_ON_CREATE_FILE, "w") as f:
        f.write("on" if val else "off")


def cmd_create_window(cwd):
    """Bound to `prefix C`: new window inheriting cwd, optional name prompt."""
    cwd = cwd or os.path.expanduser("~")
    subprocess.run(["tmux", "new-window", "-c", cwd])
    if get_prompt_on_create():
        subprocess.run(["tmux", "command-prompt",
                        "-p", "name:", "rename-window '%%'"])


def cmd_create_split(cwd):
    """Bound to `prefix o`: vertical split inheriting cwd. No rename prompt."""
    cwd = cwd or os.path.expanduser("~")
    subprocess.run(["tmux", "split-window", "-v", "-c", cwd])


FORK_HELP = """Fork the current agent context into a new tmux window.

Usage:
  tmux-compose fork local [OPTIONS]
  tmux-compose fork worktree [OPTIONS]
  tmux-compose fork --help

Modes:
  local
      Same-directory fork. Creates a new tmux window in --cwd, starts a forked
      agent in pane 0, opens a shell in pane 1, and focuses pane 0. This is
      what prefix+k uses. No git state is changed.

  worktree
      Git worktree fork. Requires --cwd to be inside a git worktree. Creates a
      new branch and physical worktree, then opens the same two-pane tmux window
      rooted in that worktree. If --branch is omitted, a unique branch named
      fork/<slug>-<timestamp> is created. If --path is omitted, the worktree is
      created as a sibling of the current repo root.

Common options:
  --cwd DIR             Source directory. Defaults to the current tmux pane path
                        when run inside tmux, otherwise the process cwd.
  -n, --name NAME       New tmux window name and Codex thread-title seed.
                        Blank/omitted uses a generated name based on the mode
                        and cwd.
  --agent AGENT         Agent to launch: codex or claude. Default: codex.
  --prompt TEXT         Optional initial prompt passed to the forked agent.
  --session-id ID       Codex only: fork this exact session id instead of
                        auto-detecting the newest session for --cwd.

Worktree-only options:
  --branch BRANCH       New git branch name to create for the worktree. Fails
                        if the branch already exists.
  --path DIR            Physical worktree directory. Defaults to a sibling of
                        the current repository root.
  --base REF            Base ref for git worktree add -b. Default: HEAD.

Agent behavior:
  codex   Uses native Codex forking. tmux-compose seeds the terminal
          title with the fork window name before launching Codex so the saved
          thread is named for that fork. By default it reads Codex session metadata,
          finds the newest recorded session whose cwd matches --cwd, and runs
          codex fork <SESSION_ID> -C <target-dir>. If no matching session is
          found, it falls back to codex fork --all --last -C <target-dir> so
          the target directory does not filter out the origin transcript.

  claude  Best-effort fallback: claude --continue --fork-session, launched in
          the target directory. Claude does not expose the same cwd-filtered
          native fork semantics as Codex here.

Examples:
  # Same-dir fork from an agent/script:
  tmux-compose fork local --cwd "$PWD" --name scratch-fork

  # Worktree fork with an automatic branch/path:
  tmux-compose fork worktree --cwd "$PWD" --name parser-experiment

  # Worktree fork with an explicit branch for a user request:
  tmux-compose fork worktree --cwd "$PWD" --name fix-window-tests \\
    --branch user/fix-window-tests --prompt "Investigate the failing window tests"
"""


def _fail(msg, code=1):
    print(f"tmux-compose fork: {msg}", file=sys.stderr)
    raise SystemExit(code)


def _run_capture(cmd, *, cwd=None, timeout=30, check=True):
    try:
        r = subprocess.run(
            cmd, cwd=cwd, capture_output=True, text=True, timeout=timeout)
    except FileNotFoundError:
        _fail(f"command not found: {cmd[0]}")
    except subprocess.TimeoutExpired:
        _fail(f"command timed out: {shlex.join(cmd)}")
    if check and r.returncode != 0:
        detail = (r.stderr or r.stdout or "").strip()
        _fail(f"command failed: {shlex.join(cmd)}" + (f"\n{detail}" if detail else ""))
    return r


def _tmux_current_path():
    r = subprocess.run(
        ["tmux", "display-message", "-p", "#{pane_current_path}"],
        capture_output=True, text=True, timeout=5)
    if r.returncode == 0 and r.stdout.strip():
        return r.stdout.strip()
    return None


def _default_cwd(cwd):
    if cwd:
        return os.path.abspath(os.path.expanduser(cwd))
    tmux_cwd = _tmux_current_path()
    if tmux_cwd:
        return os.path.abspath(os.path.expanduser(tmux_cwd))
    return os.getcwd()


def _slug(s):
    s = (s or "fork").strip().lower()
    s = re.sub(r"[^a-z0-9._/-]+", "-", s)
    s = re.sub(r"-+", "-", s).strip("-/. ")
    return s or "fork"


def _path_slug(s):
    return _slug(s).replace("/", "-")


def _default_window_name(mode, cwd, name):
    name = (name or "").strip()
    if name:
        return name
    base = os.path.basename(os.path.abspath(cwd)) or "cwd"
    return f"{mode}-{base}"



CODEX_SESSIONS_DIR = os.path.expanduser("~/.codex/sessions")


def _latest_codex_session_id_for_cwd(cwd):
    if not cwd:
        return None
    root = CODEX_SESSIONS_DIR
    if not os.path.isdir(root):
        return None

    wanted = os.path.realpath(os.path.abspath(os.path.expanduser(cwd)))
    best = None
    for dirpath, _, filenames in os.walk(root):
        for filename in filenames:
            if not filename.endswith(".jsonl"):
                continue
            path = os.path.join(dirpath, filename)
            try:
                with open(path, encoding="utf-8") as f:
                    record = json.loads(f.readline())
                if record.get("type") != "session_meta":
                    continue
                payload = record.get("payload") or {}
                session_cwd = payload.get("cwd")
                session_id = payload.get("id")
                if not session_cwd or not session_id:
                    continue
                session_cwd = os.path.realpath(
                    os.path.abspath(os.path.expanduser(session_cwd)))
                if session_cwd != wanted:
                    continue
                score = (os.path.getmtime(path), payload.get("timestamp") or "")
                if best is None or score > best[0]:
                    best = (score, session_id)
            except (OSError, json.JSONDecodeError, TypeError, ValueError):
                continue
    return best[1] if best else None


def _agent_command(agent, target_dir, session_id=None, prompt=None, window_name=None):
    if agent == "codex":
        if not shutil.which("codex"):
            _fail("codex not found on PATH")
        cmd = ["codex", "fork"]
        if session_id:
            cmd.append(session_id)
        else:
            # Fallback when Codex metadata cannot identify the source cwd.
            cmd.extend(["--all", "--last"])
        cmd.extend(["-C", target_dir])
        if prompt:
            cmd.append(prompt)
        return cmd
    if agent == "claude":
        if not shutil.which("claude"):
            _fail("claude not found on PATH")
        cmd = ["claude", "--continue", "--fork-session"]
        if window_name:
            cmd.extend(["--name", window_name])
        if prompt:
            cmd.append(prompt)
        return cmd
    _fail(f"unsupported agent: {agent}")


def _agent_shell_command(window_name, agent_cmd):
    safe_title = window_name.replace("\033", "").replace("\007", "")
    return f"printf '\033]0;%s\007' {shlex.quote(safe_title)}; exec {shlex.join(agent_cmd)}"


def _launch_fork_window(window_name, target_dir, agent_cmd, quiet=False):
    if not shutil.which("tmux"):
        _fail("tmux not found on PATH")
    if not os.path.isdir(target_dir):
        _fail(f"target directory does not exist: {target_dir}")

    r = _run_capture([
        "tmux", "new-window",
        "-n", window_name,
        "-c", target_dir,
        "-P", "-F", "#{window_id}\t#{pane_id}",
        _agent_shell_command(window_name, agent_cmd),
    ])
    parts = r.stdout.strip().split("\t")
    if len(parts) != 2:
        _fail("tmux did not return new window/pane ids")
    window_id, agent_pane = parts

    subprocess.run(["tmux", "set-window-option", "-t", window_id,
                    "automatic-rename", "off"], capture_output=True)
    subprocess.run(["tmux", "select-pane", "-t", agent_pane, "-T", "agent"],
                   capture_output=True)

    r = _run_capture([
        "tmux", "split-window", "-v",
        "-c", target_dir,
        "-t", agent_pane,
        "-P", "-F", "#{pane_id}",
    ])
    shell_pane = r.stdout.strip()
    if shell_pane:
        subprocess.run(["tmux", "select-pane", "-t", shell_pane, "-T", "shell"],
                       capture_output=True)

    subprocess.run(["tmux", "select-window", "-t", window_id], capture_output=True)
    subprocess.run(["tmux", "select-pane", "-t", agent_pane], capture_output=True)
    if not quiet:
        print(f"created {window_name}: agent pane {agent_pane}, shell pane {shell_pane}, cwd {target_dir}")


def _git_root(cwd):
    r = subprocess.run(
        ["git", "-C", cwd, "rev-parse", "--show-toplevel"],
        capture_output=True, text=True)
    if r.returncode != 0:
        return None
    return os.path.abspath(r.stdout.strip())


def _branch_exists(root, branch):
    r = subprocess.run(
        ["git", "-C", root, "show-ref", "--verify", "--quiet", f"refs/heads/{branch}"],
        capture_output=True)
    return r.returncode == 0


def _validate_branch(root, branch):
    r = subprocess.run(
        ["git", "-C", root, "check-ref-format", "--branch", branch],
        capture_output=True, text=True)
    if r.returncode != 0:
        detail = (r.stderr or r.stdout or "invalid branch name").strip()
        _fail(f"invalid branch name {branch!r}: {detail}")


def _prepare_worktree(cwd, name, branch, worktree_dir, base_ref):
    root = _git_root(cwd)
    if not root:
        _fail(f"worktree mode requires --cwd inside a git repository: {cwd}")

    timestamp = datetime.now().strftime("%Y%m%d-%H%M%S")
    branch_slug = _slug(branch) if branch else f"fork/{_slug(name)}-{timestamp}"
    _validate_branch(root, branch_slug)
    if _branch_exists(root, branch_slug):
        _fail(f"branch already exists: {branch_slug}")

    path_slug = _path_slug(branch_slug)
    wt_dir = os.path.abspath(os.path.expanduser(worktree_dir)) if worktree_dir else \
        os.path.join(os.path.dirname(root), f"{os.path.basename(root)}-{path_slug}")
    if os.path.exists(wt_dir):
        _fail(f"worktree path already exists: {wt_dir}")
    os.makedirs(os.path.dirname(wt_dir), exist_ok=True)

    _run_capture(["git", "-C", root, "worktree", "add", "-b", branch_slug, wt_dir, base_ref], timeout=120)

    rel = os.path.relpath(cwd, root)
    target_dir = wt_dir if rel == "." else os.path.join(wt_dir, rel)
    if not os.path.isdir(target_dir):
        target_dir = wt_dir
    return wt_dir, target_dir, branch_slug


def _fork_parser():
    parser = argparse.ArgumentParser(
        prog="tmux-compose fork",
        description="Fork the current Codex/Claude context into a new tmux window.",
        epilog=FORK_HELP,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    parser.add_argument("mode", nargs="?", choices=("local", "worktree"), default="local")
    parser.add_argument("--cwd", help="source directory; defaults to current tmux pane path")
    parser.add_argument("-n", "--name", help="new tmux window name")
    parser.add_argument("--agent", choices=("codex", "claude"), default="codex")
    parser.add_argument("--prompt", help="optional initial prompt for the forked agent")
    parser.add_argument("--session-id", help="Codex session id to fork instead of auto-detection")
    parser.add_argument("--branch", help="worktree mode: branch name to create")
    parser.add_argument("--path", dest="worktree_dir", help="worktree mode: physical worktree directory")
    parser.add_argument("--base", default="HEAD", help="worktree mode: base ref for git worktree add -b")
    parser.add_argument("--quiet", action="store_true", help="suppress status output; used by tmux keybindings")
    return parser


def cmd_fork(args):
    if args and args[0] in ("-h", "--help"):
        print(FORK_HELP)
        return
    ns = _fork_parser().parse_args(args)
    cwd = _default_cwd(ns.cwd)
    if not os.path.isdir(cwd):
        _fail(f"cwd does not exist: {cwd}")

    window_name = _default_window_name(ns.mode, cwd, ns.name)
    target_dir = cwd
    if ns.mode == "worktree":
        wt_dir, target_dir, branch = _prepare_worktree(
            cwd, window_name, ns.branch, ns.worktree_dir, ns.base)
        if not ns.quiet:
            print(f"created worktree {wt_dir} on branch {branch}")

    session_id = ns.session_id
    if ns.agent == "codex" and not session_id:
        session_id = _latest_codex_session_id_for_cwd(cwd)

    agent_cmd = _agent_command(
        ns.agent, target_dir, session_id=session_id,
        prompt=ns.prompt, window_name=window_name)
    _launch_fork_window(window_name, target_dir, agent_cmd, quiet=ns.quiet)


def cmd_fork_prompt(args):
    mode = args[0] if args else "local"
    cwd = args[1] if len(args) > 1 else _default_cwd(None)
    if mode not in ("local", "worktree"):
        _fail("fork-prompt mode must be local or worktree")
    script = os.path.abspath(shutil.which(sys.argv[0]) or sys.argv[0])
    prompt = "fork window name:"
    fork_cmd = (
        f"{shlex.quote(script)} fork {mode} --cwd {shlex.quote(cwd)} "
        "--name '%1' --agent codex --quiet")
    if mode == "worktree":
        prompt = "fork window name:,branch name:"
        fork_cmd += " --branch '%2'"
    command = "run-shell " + shlex.quote(fork_cmd)
    subprocess.run(["tmux", "command-prompt", "-p", prompt, command])


def cmd_toggle_prompt_on_create():
    new_val = not get_prompt_on_create()
    set_prompt_on_create(new_val)
    print("on" if new_val else "off")


# --- codex auto_approve_edits toggle ------------------------------------
# Lives in codex.toml (read by codex-auto-approve daemon) so a single
# source of truth. Hand-edits the line so toml comments are preserved.
CODEX_TOML_PATH = os.path.expanduser("~/.config/auto-approve/codex.toml")
_CODEX_EDITS_RE = re.compile(
    r"^(\s*auto_approve_edits\s*=\s*)(true|false)\b", re.MULTILINE)


def get_codex_auto_edits():
    try:
        with open(CODEX_TOML_PATH) as f:
            content = f.read()
    except FileNotFoundError:
        return False
    m = _CODEX_EDITS_RE.search(content)
    return bool(m) and m.group(2) == "true"


def cmd_toggle_codex_auto_edits():
    """Flip auto_approve_edits in codex.toml and restart the daemon."""
    try:
        with open(CODEX_TOML_PATH) as f:
            content = f.read()
    except FileNotFoundError:
        print("off")
        return
    m = _CODEX_EDITS_RE.search(content)
    if not m:
        print("off")
        return
    new_val = "false" if m.group(2) == "true" else "true"
    new_content = content[:m.start(2)] + new_val + content[m.end(2):]
    with open(CODEX_TOML_PATH, "w") as f:
        f.write(new_content)
    subprocess.run(
        ["systemctl", "--user", "restart", "codex-auto-approve.service"],
        capture_output=True,
    )
    print("on" if new_val == "true" else "off")


# --- codex approve_all toggle -------------------------------------------
# Flips between allowlist mode (approve only safe_patterns) and approve-all
# mode (approve everything except deny_patterns). Same single-source-of-truth
# hand-edit approach as the auto_approve_edits toggle above.
_CODEX_APPROVE_ALL_RE = re.compile(
    r"^(\s*approve_all\s*=\s*)(true|false)\b", re.MULTILINE)


def get_codex_approve_all():
    try:
        with open(CODEX_TOML_PATH) as f:
            content = f.read()
    except FileNotFoundError:
        return False
    m = _CODEX_APPROVE_ALL_RE.search(content)
    return bool(m) and m.group(2) == "true"


def cmd_toggle_codex_approve_all():
    """Flip approve_all in codex.toml and restart the daemon."""
    try:
        with open(CODEX_TOML_PATH) as f:
            content = f.read()
    except FileNotFoundError:
        print("off")
        return
    m = _CODEX_APPROVE_ALL_RE.search(content)
    if not m:
        print("off")
        return
    new_val = "false" if m.group(2) == "true" else "true"
    new_content = content[:m.start(2)] + new_val + content[m.end(2):]
    with open(CODEX_TOML_PATH, "w") as f:
        f.write(new_content)
    subprocess.run(
        ["systemctl", "--user", "restart", "codex-auto-approve.service"],
        capture_output=True,
    )
    print("on" if new_val == "true" else "off")

HELP_TEXT = r"""
  tmux-compose — terminal toolkit
  ================================

  TMUX KEYBINDINGS
  -----------------
  prefix+h  History    View current pane's scrollback (ANSI colors)
  prefix+e  Compose    Write text to send to pane or clipboard
  prefix+t  Terminals  Browse all saved terminal histories
  prefix+S  Status     View/control background daemons
  prefix+T  Todo       Manage todo items (synced to ~/todo/todo.md)
  prefix+b  Btop       System resource monitor; prefix+b again jumps back (btop stays running)
  prefix+r  Back       Jump to previous pane (jumplist)
  prefix+f  Forward    Jump to next pane (jumplist)
  prefix+j  Jumplist   Pick from recent pane visits
  prefix+c/C Create    New window in current pane directory
  prefix+o  Split      Vertical split in current pane directory
  prefix+k  Fork       Fork current agent context in a new local window
  prefix+K  Worktree   Fork current agent context into a new git worktree

  WINDOW KEYBINDINGS (inside tmux-compose)
  --------------------------------------
  qh        Switch to history window
  qe        Switch to compose window
  qt        Switch to terminals window
  qS        Switch to status window
  ?         Switch to help window
  qq        Jump back to previous session (where you came from)

  COMPOSE KEYS
  -------------
  qa        Send compose text to source pane + jump back
  qw        Copy compose text to clipboard + jump back
  :w/:wq    Disabled — use qa or qw

  TERMINALS KEYS
  ---------------
  Enter     View selected terminal's full history
  /         Search all terminals (regex)
  n         Edit note for selected terminal
  qq        Jump back

  STATUS KEYS
  ------------
  r         Restart service on current line
  s         Start service on current line
  R         Refresh all statuses
  qq        Jump back

  TODO KEYS
  ----------
  a         Add new todo item
  d         Toggle status (TODO → IN-PROGRESS → DONE)
  e         Edit item in ~/todo/todo.md (opens real file)
  Enter     Focus detail pane for scrolling
  R         Refresh from file
  qq        Jump back

  JUMPLIST
  ---------
  The jumplist tracks every pane you visit. Use prefix+r to go back
  and prefix+f to go forward, like browser history. Dead panes are
  skipped automatically.

  prefix+j opens a picker showing recent pane visits — select one
  to jump directly there.

  FORK
  -----
  prefix+k prompts for a window name and opens a same-directory Codex fork in
  a new tmux window. prefix+K prompts for a window name and branch name,
  creates a git worktree fork, and opens the same two-pane Codex layout there.
  The new window has pane 0 running the forked agent and pane 1 as a shell.
  Focus stays on pane 0.

  Agents/scripts can use the CLI form:
    tmux-compose fork --help
    tmux-compose fork local --cwd DIR --name NAME
    tmux-compose fork worktree --cwd DIR --name NAME [--branch BRANCH]

  DATA STORAGE
  -------------
  Database: ~/.cache/tmux/pane-history.db (SQLite, WAL mode)
  State:    ~/.cache/tmux/compose-state/

  Tables:
    captures       Individual pane scrollback snapshots
    merged         Deduplicated merged history per pane lifecycle
    compositions   Saved compose outputs
    terminal_notes User memos attached to terminals
    jumplist       Pane visit history for navigation

  RESET
  ------
  Run: tmux-compose reset
  This kills the tmux-compose session and wipes state. Next prefix+h
  recreates everything fresh.
"""


# ---------------------------------------------------------------------------
# Database helpers
# ---------------------------------------------------------------------------

def strip_vt100_controls(text):
    return _VT100_CTRL_RE.sub("", text)


def ensure_tables():
    if not os.path.exists(os.path.dirname(DB_PATH)):
        os.makedirs(os.path.dirname(DB_PATH), exist_ok=True)
    conn = sqlite3.connect(DB_PATH)
    conn.execute("PRAGMA journal_mode=WAL")
    conn.execute("""
        CREATE TABLE IF NOT EXISTS compositions (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            pane_id TEXT, content TEXT,
            created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        )
    """)
    conn.execute("""
        CREATE TABLE IF NOT EXISTS terminal_notes (
            pane_id TEXT PRIMARY KEY, note TEXT
        )
    """)
    conn.commit()
    conn.close()


def save_composition(label, content):
    if not content.strip():
        return
    ensure_tables()
    conn = sqlite3.connect(DB_PATH)
    conn.execute("PRAGMA journal_mode=WAL")
    conn.execute(
        "INSERT INTO compositions (pane_id, content, created_at) VALUES (?, ?, ?)",
        (label, content, datetime.now().isoformat()),
    )
    conn.commit()
    conn.close()


def get_recent_compositions(n=20):
    ensure_tables()
    if not os.path.exists(DB_PATH):
        return []
    conn = sqlite3.connect(DB_PATH)
    conn.execute("PRAGMA journal_mode=WAL")
    rows = conn.execute(
        "SELECT content, created_at, pane_id FROM compositions ORDER BY id DESC LIMIT ?",
        (n,),
    ).fetchall()
    conn.close()
    return rows


def get_terminal_histories():
    if not os.path.exists(DB_PATH):
        return []
    conn = sqlite3.connect(DB_PATH)
    conn.execute("PRAGMA journal_mode=WAL")
    rows = conn.execute("""
        SELECT m.pane_id, length(m.content),
               (SELECT max(c.captured_at) FROM captures c WHERE c.pane_id = m.pane_id),
               m.label
        FROM merged m
        WHERE m.label NOT LIKE 'tmux-compose:%'
        ORDER BY (SELECT max(c.captured_at) FROM captures c WHERE c.pane_id = m.pane_id) DESC
    """).fetchall()
    conn.close()
    return rows


def get_merged_history(pane_id):
    if not os.path.exists(DB_PATH):
        return ""
    conn = sqlite3.connect(DB_PATH)
    conn.execute("PRAGMA journal_mode=WAL")
    row = conn.execute(
        "SELECT content FROM merged WHERE pane_id = ?", (pane_id,)
    ).fetchone()
    if not row and "@" in pane_id:
        bare = pane_id.split("@")[0]
        old = conn.execute(
            "SELECT content FROM merged WHERE pane_id = ?", (bare,)
        ).fetchone()
        conn.close()
        return old[0] if old else ""
    conn.close()
    return row[0] if row else ""


def get_merged_history_tail(pane_id, max_lines=500):
    content = get_merged_history(pane_id)
    if not content:
        return ""
    lines = content.split("\n")
    if len(lines) > max_lines:
        lines = lines[-max_lines:]
    return strip_vt100_controls("\n".join(lines))


def resolve_terminal_key(pane_id):
    try:
        out = subprocess.check_output(
            ["tmux", "list-panes", "-a", "-F",
             "#{pane_id}\t#{pane_pid}",
             "-f", "#{==:#{pane_id}," + pane_id + "}"],
            text=True,
        ).strip()
        parts = out.split("\t")
        if len(parts) == 2 and parts[1]:
            return f"{parts[0]}@{parts[1]}"
    except subprocess.CalledProcessError:
        pass
    return pane_id


def get_notes():
    ensure_tables()
    if not os.path.exists(DB_PATH):
        return {}
    conn = sqlite3.connect(DB_PATH)
    rows = conn.execute("SELECT pane_id, note FROM terminal_notes").fetchall()
    conn.close()
    return {r[0]: r[1] for r in rows}


def set_note(pane_id, note):
    ensure_tables()
    conn = sqlite3.connect(DB_PATH)
    conn.execute("PRAGMA journal_mode=WAL")
    if note.strip():
        conn.execute(
            "INSERT OR REPLACE INTO terminal_notes (pane_id, note) VALUES (?, ?)",
            (pane_id, note),
        )
    else:
        conn.execute("DELETE FROM terminal_notes WHERE pane_id = ?", (pane_id,))
    conn.commit()
    conn.close()


def search_terminals(pattern):
    if not os.path.exists(DB_PATH):
        return {}
    conn = sqlite3.connect(DB_PATH)
    conn.execute("PRAGMA journal_mode=WAL")
    rows = conn.execute("SELECT pane_id, content FROM merged").fetchall()
    conn.close()
    results = {}
    try:
        rx = re.compile(pattern, re.IGNORECASE)
    except re.error:
        return {}
    for pane_id, content in rows:
        clean = re.sub(r"\033\[[0-9;]*[a-zA-Z]", "", content)
        matches = rx.findall(clean)
        if matches:
            results[pane_id] = len(matches)
    return results


def get_pane_label(pane_id):
    try:
        return subprocess.check_output(
            ["tmux", "display-message", "-t", pane_id, "-p",
             "#{session_name}:#{window_index}.#{pane_index}"],
            text=True,
        ).strip()
    except subprocess.CalledProcessError:
        return pane_id


# ---------------------------------------------------------------------------
# Todo helpers
# ---------------------------------------------------------------------------

def parse_todo_items():
    """Parse ~/todo/todo.md into a list of item dicts."""
    if not os.path.exists(TODO_PATH):
        return []
    with open(TODO_PATH, "r") as f:
        lines = f.readlines()
    items = []
    i = 0
    header_re = re.compile(r"^##\s+\[(\w[\w-]*)\]\s+(.+?)\s*\{{3}\s*$")
    while i < len(lines):
        m = header_re.match(lines[i])
        if m:
            status = m.group(1)
            title = m.group(2)
            line_start = i + 1  # 1-indexed
            # Collect body until matching closing }}}
            depth = 1
            body_lines = []
            j = i + 1
            while j < len(lines) and depth > 0:
                if "{{{" in lines[j]:
                    depth += 1
                if "}}}" in lines[j]:
                    depth -= 1
                    if depth == 0:
                        break
                body_lines.append(lines[j])
                j += 1
            line_end = j + 1  # 1-indexed, inclusive of closing }}}
            body = "".join(body_lines)
            # Extract fields
            synopsis = ""
            due = ""
            tags = ""
            details_lines = []
            in_details = False
            details_depth = 0
            for bl in body_lines:
                stripped = bl.strip()
                if stripped.startswith("**Synopsis:**"):
                    synopsis = stripped.replace("**Synopsis:**", "").strip()
                elif stripped.startswith("**Due:**"):
                    due = stripped.replace("**Due:**", "").strip()
                elif stripped.startswith("**Tags:**"):
                    tags = stripped.replace("**Tags:**", "").strip()
                elif stripped.startswith("**Details:**"):
                    in_details = True
                    details_depth = 1
                elif in_details:
                    if "{{{" in bl:
                        details_depth += 1
                    if "}}}" in bl:
                        details_depth -= 1
                        if details_depth <= 0:
                            in_details = False
                            continue
                    details_lines.append(bl)
            items.append({
                "status": status,
                "title": title,
                "synopsis": synopsis,
                "due": due,
                "tags": tags,
                "details": "".join(details_lines).strip(),
                "body": body.strip(),
                "line_start": line_start,
                "line_end": line_end,
            })
            i = j + 1
        else:
            i += 1
    return items


def refresh_todo_data():
    """Write todo.json and detail files to STATE_DIR."""
    items = parse_todo_items()
    details_dir = os.path.join(STATE_DIR, "todo_details")
    if os.path.exists(details_dir):
        shutil.rmtree(details_dir)
    os.makedirs(details_dir, exist_ok=True)

    # Group order for display
    status_order = {"TODO": 0, "IN-PROGRESS": 1, "NOTE": 2, "DONE": 3}
    items.sort(key=lambda x: status_order.get(x["status"], 99))

    todo_data = []
    for idx, item in enumerate(items):
        detail_path = os.path.join(details_dir, f"item_{idx}.txt")
        detail_text = (
            f"[{item['status']}] {item['title']}\n"
            f"{'=' * (len(item['title']) + len(item['status']) + 3)}\n\n"
            f"Due:      {item['due']}\n"
            f"Synopsis: {item['synopsis']}\n"
            f"Tags:     {item['tags']}\n\n"
            f"Details:\n{item['details']}\n"
        )
        with open(detail_path, "w") as f:
            f.write(detail_text)
        todo_data.append({
            "status": item["status"],
            "title": item["title"],
            "synopsis": item["synopsis"],
            "due": item["due"],
            "tags": item["tags"],
            "line_start": item["line_start"],
            "line_end": item["line_end"],
            "detail_path": detail_path,
        })
    with open(os.path.join(STATE_DIR, "todo.json"), "w") as f:
        json.dump(todo_data, f)


def git_commit_todo(message):
    """Stage and commit todo.md."""
    subprocess.run(["git", "-C", TODO_REPO, "add", "todo.md"], capture_output=True)
    subprocess.run(["git", "-C", TODO_REPO, "commit", "-m", message], capture_output=True)


def cmd_todo_add(args):
    """Add a new todo item and commit."""
    if not args:
        return
    title = " ".join(args)
    new_item = "\n\n## [TODO] %s {{{\n\n" \
               "**Due:** TBD\n" \
               "**Synopsis:** %s\n\n\n" \
               "**Details:**  {{{\n" \
               "* \n" \
               "}}}\n\n" \
               "**Tags:** \n\n" \
               "}}}\n" % (title, title)
    with open(TODO_PATH, "r") as f:
        content = f.read()
    # Insert before the vim modeline
    modeline_re = re.compile(r"\n(# vim:.*$)", re.MULTILINE)
    m = modeline_re.search(content)
    if m:
        content = content[:m.start()] + new_item + "\n" + m.group(1) + "\n"
    else:
        content += new_item
    with open(TODO_PATH, "w") as f:
        f.write(content)
    git_commit_todo(f"Add item - {title}")
    print(json.dumps({"ok": True}))


def cmd_todo_update_status(args):
    """Update an item's status and commit. Args: line_start new_status."""
    if len(args) < 2:
        return
    line_num = int(args[0])
    new_status = args[1]
    with open(TODO_PATH, "r") as f:
        lines = f.readlines()
    idx = line_num - 1
    if idx < 0 or idx >= len(lines):
        return
    header_re = re.compile(r"^(##\s+)\[(\w[\w-]*)\](\s+.+)$")
    m = header_re.match(lines[idx])
    if not m:
        return
    old_status = m.group(2)
    title_part = m.group(3).rstrip()
    lines[idx] = f"{m.group(1)}[{new_status}]{title_part}\n"
    with open(TODO_PATH, "w") as f:
        f.writelines(lines)
    # Extract title for commit message
    title = title_part.replace("{{{", "").strip()
    git_commit_todo(f"Update item ({old_status} -> {new_status}) - {title}")
    print(json.dumps({"ok": True}))


# ---------------------------------------------------------------------------
# Subcommand handlers (called from lua via vim.fn.system)
# ---------------------------------------------------------------------------

def cmd_search(args):
    print(json.dumps(search_terminals(args[0]) if args else {}))


def cmd_note(args):
    if len(args) < 1:
        return
    if len(args) > 1:
        set_note(args[0], " ".join(args[1:]))
    else:
        notes = get_notes()
        print(notes.get(args[0], ""))


def cmd_dump(args):
    if len(args) < 2:
        return
    content = get_merged_history(args[0])
    with open(args[1], "w") as f:
        f.write(strip_vt100_controls(content))


def cmd_status(args):
    results = []
    for svc in SERVICES:
        try:
            out = subprocess.check_output(
                ["systemctl", "--user", "show", svc + ".service",
                 "--property=ActiveState,SubState,MainPID,ExecMainStartTimestamp"],
                text=True,
            )
            props = {}
            for line in out.strip().split("\n"):
                if "=" in line:
                    k, v = line.split("=", 1)
                    props[k] = v
            results.append({
                "name": svc,
                "state": props.get("ActiveState", "unknown"),
                "pid": props.get("MainPID", "0"),
                "started": props.get("ExecMainStartTimestamp", ""),
            })
        except subprocess.CalledProcessError:
            results.append({"name": svc, "state": "unknown", "pid": "0", "started": ""})
    print(json.dumps(results))


