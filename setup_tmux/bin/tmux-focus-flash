#!/usr/bin/env bash
set -euo pipefail

socket_path="${1:-}"
tmux_cmd=(tmux)
if [[ -n "$socket_path" ]]; then
  tmux_cmd=(tmux -S "$socket_path")
fi

"${tmux_cmd[@]}" has-session >/dev/null 2>&1 || exit 0

option_or_default() {
  local name="$1"
  local default="$2"
  local value

  value="$("${tmux_cmd[@]}" show-option -gqv "$name" 2>/dev/null || true)"
  if [[ -n "$value" ]]; then
    printf '%s' "$value"
  else
    printf '%s' "$default"
  fi
}

delay="${TMUX_FOCUS_FLASH_DELAY:-0.10}"

normal_pane_format="$(option_or_default @focus_flash_pane_format_normal '#{?pane_active,#[fg=black#{,}bg=white#{,}bold] [●] #{pane_index} #[default],#[fg=colour244#{,}bg=default] [○] #{pane_index} #[default]}')"
disabled_pane_format="$(option_or_default @focus_flash_pane_format_disabled '#{?pane_active,#[fg=colour244#{,}bg=default] [●] #{pane_index} #[default],#[fg=colour244#{,}bg=default] [○] #{pane_index} #[default]}')"
normal_active_border_style="$(option_or_default @focus_flash_pane_active_border_style_normal 'fg=white,bg=default,bold')"
disabled_active_border_style="$(option_or_default @focus_flash_pane_active_border_style_disabled 'fg=colour238,bg=default')"

set_flash() {
  local state="$1"
  local pane_format
  local active_border_style

  case "$state" in
    normal|white)
      pane_format="$normal_pane_format"
      active_border_style="$normal_active_border_style"
      ;;
    disabled)
      pane_format="$disabled_pane_format"
      active_border_style="$disabled_active_border_style"
      ;;
    *)
      pane_format="$normal_pane_format"
      active_border_style="$normal_active_border_style"
      ;;
  esac

  "${tmux_cmd[@]}" set-option -gq pane-border-format "$pane_format" || true
  "${tmux_cmd[@]}" set-option -gq pane-active-border-style "$active_border_style" || true
  "${tmux_cmd[@]}" refresh-client 2>/dev/null || true
}

trap 'set_flash normal' EXIT

states=(white disabled white disabled white disabled white)
last_index=$((${#states[@]} - 1))
for i in "${!states[@]}"; do
  set_flash "${states[$i]}"
  if (( i < last_index )); then
    sleep "$delay"
  fi
done
