{
  "languageserver": {
    "ccls": {
      "command": "ccls-docker",
      "filetypes": ["c", "cpp", "cuda", "objc", "objcpp"],
      "rootPatterns": [".ccls-root", "compile_commands.json"],
      "initializationOptions": {
        "cache": {
          "directory": ".ccls-cache"
        },
        "client": {
          "snippetSupport": true
        }
      }
    }
  },
  "java.jdt.ls.vmargs": "-Xms256m -Xmx8G -XX:+UseG1GC -XX:+UseStringDeduplication"
}
